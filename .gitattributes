# 强制所有源代码文件使用 LF 换行符，防止 Windows 带入 CRLF
*.cc    text eol=lf
*.h     text eol=lf
*.hpp   text eol=lf
*.cpp   text eol=lf
*.c     text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.cmake text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.vue   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
CMakeLists.txt text eol=lf
Makefile       text eol=lf

# 二进制文件不做转换
*.bmodel binary
*.so     binary
*.a      binary
*.png    binary
*.jpg    binary
*.webp   binary
*.mp4    binary
*.tar.gz binary
